#!/bin/sh
# Enforce Conventional Commits format
commit_msg=$(cat "$1")

pattern='^(feat|fix|chore|style|refactor|docs|test|build|ci|perf)(\(.+\))?: .+'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "COMMIT REJECTED: message doesn't follow Conventional Commits."
  echo "  Format:  <type>(<scope>): <description>"
  echo "  Types:   feat, fix, chore, style, refactor, docs, test, build, ci, perf"
  echo "  Example: feat: add contact form email delivery (#12)"
  echo ""
  exit 1
fi
