#!/bin/sh
# Block direct push to main — all changes must go through a PR
current_branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$current_branch" = "main" ]; then
  echo ""
  echo "PUSH REJECTED: direct push to main is not allowed."
  echo "  Create a feature branch: feat/<issue-number>-<description>"
  echo "  Then open a PR to merge into main."
  echo ""
  exit 1
fi
